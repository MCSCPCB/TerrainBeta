{
  "format_version": "1.10.0",
  "render_controllers": {
    "controller.render.terrainbeta.alpha_fog_anchor.depth": {
      "geometry": "Geometry.alpha_fog_clip_depth",
      "textures": [
        "Texture.alpha_fog_shell"
      ],
      "ignore_lighting": false,
      "on_fire_color": {},
      "materials": [
        {
          "*": "Material.default"
        },
        {
          "skyboxdepthtest*": "Material.skyboxdepthtest"
        }
      ]
    },
    "controller.render.terrainbeta.alpha_fog_anchor.color": {
      "geometry": "Geometry.alpha_fog_clip_color",
      "textures": [
        "Texture.alpha_fog_shell"
      ],
      "ignore_lighting": false,
      "overlay_color": {
        "r": 0,
        "g": 0,
        "b": 0,
        "a": "q.time_of_day >= 0.68 ? math.hermite_blend(math.clamp((q.time_of_day - 0.68) / 0.14, 0, 1)) : (q.time_of_day <= 0.32 ? (1 - math.hermite_blend(math.clamp((q.time_of_day - 0.18) / 0.14, 0, 1))) : 0)"
      },
      "on_fire_color": {},
      "materials": [
        {
          "*": "Material.default"
        },
        {
          "skyboxcolorwrite*": "Material.skyboxcolorwrite"
        }
      ]
    }
  }
}

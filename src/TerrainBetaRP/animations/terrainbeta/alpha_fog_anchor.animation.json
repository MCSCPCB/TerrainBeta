{
  "format_version": "1.8.0",
  "animations": {
    "animation.terrainbeta.alpha_fog_anchor.offset": {
      "loop": true,
      "bones": {
        "elementsSkybox": {
          "position": [
            "16*v.cam_pos_x",
            "16*v.cam_pos_y",
            "-16*v.cam_pos_z"
          ],
          "rotation": [
            "- query.body_x_rotation",
            "- query.body_y_rotation",
            0.0
          ]
        },
        "skyboxColorWrite": {
          "scale": [
            "q.time_of_day >= 0.291667 && q.time_of_day <= 0.736111 ? 16.0 : 1.0 + 15.0 * math.abs(math.cos(q.time_of_day * 360.0)) * math.abs(math.cos(q.time_of_day * 360.0))",
            "q.time_of_day >= 0.291667 && q.time_of_day <= 0.736111 ? 16.0 : 1.0 + 15.0 * math.abs(math.cos(q.time_of_day * 360.0)) * math.abs(math.cos(q.time_of_day * 360.0))",
            "q.time_of_day >= 0.291667 && q.time_of_day <= 0.736111 ? 16.0 : 1.0 + 15.0 * math.abs(math.cos(q.time_of_day * 360.0)) * math.abs(math.cos(q.time_of_day * 360.0))"
          ]
        }
      }
    }
  }
}
